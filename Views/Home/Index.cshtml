@{
    ViewData["Title"] = ViewData["SiteTitle"] ?? "族谱管理系统";
    ViewData["FullWidth"] = true;
}

<!-- Toolbar -->
<div class="tree-toolbar no-print">
    <div class="toolbar-left">
        <h5 class="mb-0 text-white">
            <i class="bi bi-diagram-3-fill me-2"></i>
            <span id="familyName">@((string?)ViewData["FamilyName"] ?? "周氏家谱")</span>
        </h5>
    </div>
    <div class="toolbar-center">
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnViewAll" title="查看全部成员">
                <i class="bi bi-people-fill me-1"></i>全部成员
            </button>
        </div>
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnStats" title="统计信息">
                <i class="bi bi-bar-chart-fill me-1"></i>统计
            </button>
        </div>
    </div>
    <div class="toolbar-right">
        <div class="input-group input-group-sm me-2" style="width: 200px;">
            <input type="text" class="form-control" id="searchInput" placeholder="搜索姓名...">
            <button class="btn btn-light" id="btnSearch">
                <i class="bi bi-search"></i>
            </button>
        </div>
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnAddRoot" title="添加成员">
                <i class="bi bi-person-plus-fill me-1"></i>添加
            </button>
        </div>
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnExport" title="导出">
                <i class="bi bi-download me-1"></i>导出
            </button>
        </div>
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnImportXmind" title="导入 XMind">
                <i class="bi bi-file-earmark-arrow-up me-1"></i>导入XMind
            </button>
        </div>
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnExportXmind" title="导出 XMind">
                <i class="bi bi-file-earmark-arrow-down me-1"></i>导出XMind
            </button>
        </div>
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnShare" title="分享">
                <i class="bi bi-share-fill me-1"></i>分享
            </button>
        </div>
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnHelp" title="帮助">
                <i class="bi bi-question-circle-fill me-1"></i>帮助
            </button>
        </div>
        <div class="btn-group me-2">
            <button class="btn btn-outline-light btn-sm" id="btnPrint" title="打印">
                <i class="bi bi-printer-fill me-1"></i>打印
            </button>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-light btn-sm" id="btnZoomIn" title="放大">
                <i class="bi bi-zoom-in"></i>
            </button>
            <button class="btn btn-outline-light btn-sm" id="btnZoomOut" title="缩小">
                <i class="bi bi-zoom-out"></i>
            </button>
            <button class="btn btn-outline-light btn-sm" id="btnZoomReset" title="重置">
                <i class="bi bi-arrows-fullscreen"></i>
            </button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace((string?)ViewData["Announcement"]))
{
    <div class="announcement-bar no-print">
        <div class="announcement-track">
            <span>@ViewData["Announcement"]</span>
            <span class="ms-5">@ViewData["Announcement"]</span>
        </div>
    </div>
}

<!-- Help Modal -->
<div class="modal fade" id="helpModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title"><i class="bi bi-question-circle-fill me-2"></i>操作帮助</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <ol>
                    <li>单击成员卡片可查看详细信息。</li>
                    <li>桌面端拖拽空白区域平移族谱；移动端单指拖拽、双指缩放。</li>
                    <li>使用顶部搜索框可快速定位成员。</li>
                    <li>管理员账号可添加、编辑、删除成员；普通账号为只读模式。</li>
                    <li>“全部成员”中点击配偶名字可打开配偶详情。</li>
                    <li>“统计”会按当前最新数据重新计算成员和辈分。</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<!-- Search Results Dropdown -->
<div id="searchResults" class="search-results-panel" style="display:none;">
    <div class="search-results-header">
        <span>搜索结果</span>
        <button class="btn btn-sm btn-close" id="btnCloseSearch"></button>
    </div>
    <div id="searchResultsList" class="search-results-list"></div>
</div>

<!-- Tree Container -->
<input type="file" id="xmindImportInput" accept=".xmind" class="d-none">
<div id="treeContainer" class="tree-container">
    <div id="loadingSpinner" class="text-center py-5">
        <div class="spinner-border text-danger" role="status">
            <span class="visually-hidden">加载中...</span>
        </div>
        <p class="mt-2 text-muted">正在加载族谱数据...</p>
    </div>
    <svg id="treeSvg"></svg>
</div>

<!-- Person Detail Modal -->
<div class="modal fade" id="personDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-person-fill me-2"></i>个人详情</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-4 text-center">
                        <div class="person-photo-large mb-3">
                            <img id="detailPhoto" src="" alt="照片" class="rounded-circle" style="width:120px;height:120px;object-fit:cover;">
                        </div>
                        <h4 id="detailName" class="mb-1"></h4>
                        <span id="detailGenderBadge" class="badge"></span>
                        <span id="detailGenerationBadge" class="badge bg-secondary ms-1"></span>
                        <span id="detailRankBadge" class="badge bg-info ms-1"></span>
                        <div class="mt-3">
                            <label class="form-label small text-muted">上传照片</label>
                            <input type="file" class="form-control form-control-sm" id="photoUpload" accept="image/*">
                        </div>
                    </div>
                    <div class="col-md-8">
                        <table class="table table-borderless">
                            <tr><td class="text-muted" style="width:100px;">姓名</td><td id="detailNameText"></td></tr>
                            <tr><td class="text-muted">性别</td><td id="detailGender"></td></tr>
                            <tr><td class="text-muted">辈分</td><td id="detailGeneration"></td></tr>
                            <tr><td class="text-muted">职业</td><td id="detailOccupation"></td></tr>
                            <tr><td class="text-muted">出生日期</td><td id="detailBirthDate"></td></tr>
                            <tr><td class="text-muted">去世日期</td><td id="detailDeathDate"></td></tr>
                            <tr><td class="text-muted">出生地</td><td id="detailBirthPlace"></td></tr>
                            <tr><td class="text-muted">现居地</td><td id="detailCurrentAddress"></td></tr>
                            <tr><td class="text-muted">电话</td><td id="detailPhone"></td></tr>
                            <tr><td class="text-muted">男性排行</td><td id="detailRank"></td></tr>
                            <tr><td class="text-muted">配偶</td><td><span id="detailSpouse"></span></td></tr>
                            <tr><td class="text-muted">父亲</td><td><span id="detailParent"></span></td></tr>
                            <tr><td class="text-muted">儿子数</td><td id="detailSons"></td></tr>
                            <tr><td class="text-muted">女儿数</td><td id="detailDaughters"></td></tr>
                            <tr><td class="text-muted">简介</td><td id="detailBiography"></td></tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" id="btnEditPerson"><i class="bi bi-pencil me-1"></i>编辑</button>
                <button class="btn btn-success" id="btnAddChild"><i class="bi bi-person-plus me-1"></i>添加子女</button>
                <button class="btn btn-info" id="btnAddSpouse"><i class="bi bi-heart me-1"></i>添加配偶</button>
                <button class="btn btn-danger" id="btnDeletePerson"><i class="bi bi-trash me-1"></i>删除</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">关闭</button>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Person Modal -->
<div class="modal fade" id="personEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="editModalTitle"><i class="bi bi-person-plus me-2"></i>添加成员</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="personForm">
                    <input type="hidden" id="editPersonId">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">姓名 <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="editName" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">性别 <span class="text-danger">*</span></label>
                            <select class="form-select" id="editGender">
                                <option value="Male">男</option>
                                <option value="Female">女</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">辈分</label>
                            <input type="text" class="form-control" id="editGeneration" placeholder="如：京、永、学、大">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">出生日期</label>
                            <input type="date" class="form-control" id="editBirthDate">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">去世日期</label>
                            <input type="date" class="form-control" id="editDeathDate">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">职业</label>
                            <input type="text" class="form-control" id="editOccupation" placeholder="名字中包含“农民”时自动识别为农民">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">出生地</label>
                            <input type="text" class="form-control" id="editBirthPlace">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">现居地</label>
                            <input type="text" class="form-control" id="editCurrentAddress">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">电话</label>
                            <input type="text" class="form-control" id="editPhone">
                        </div>
                    </div>
                    <div class="alert alert-light small mb-3">
                        男性排行按同代男性出生日期自动计算，不能手动修改。
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">父亲</label>
                            <select class="form-select" id="editParentId">
                                <option value="">-- 无 --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">配偶</label>
                            <select class="form-select" id="editSpouseId">
                                <option value="">-- 无 --</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">个人简介</label>
                        <textarea class="form-control" id="editBiography" rows="3"></textarea>
                    </div>
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="editIsRoot">
                        <label class="form-check-label" for="editIsRoot">设为始祖（族谱根节点）</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" id="btnSavePerson"><i class="bi bi-check-lg me-1"></i>保存</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
            </div>
        </div>
    </div>
</div>

<!-- All Members Modal -->
<div class="modal fade" id="allMembersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-people-fill me-2"></i>全部成员</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-hover table-striped" id="membersTable">
                        <thead class="table-dark">
                            <tr>
                                <th>姓名</th>
                                <th>性别</th>
                                <th>辈分</th>
                                <th>职业</th>
                                <th>出生日期</th>
                                <th>配偶</th>
                                <th>父亲</th>
                                <th>排行</th>
                                <th>儿子</th>
                                <th>女儿</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody id="membersTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Modal -->
<div class="modal fade" id="statsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="bi bi-bar-chart-fill me-2"></i>族谱统计</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="statsBody">
            </div>
        </div>
    </div>
</div>

<!-- Share Modal -->
<div class="modal fade" id="shareModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-share-fill me-2"></i>分享族谱</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>点击下方按钮生成分享链接，有效期30天。</p>
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="shareUrl" readonly placeholder="点击生成按钮获取链接">
                    <button class="btn btn-outline-success" id="btnCopyShare">
                        <i class="bi bi-clipboard me-1"></i>复制
                    </button>
                </div>
                <button class="btn btn-success w-100" id="btnGenerateShare">
                    <i class="bi bi-link-45deg me-1"></i>生成分享链接
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="~/js/familytree.js" asp-append-version="true"></script>
}
